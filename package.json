{
  "name": "wireface",
  "version": "1.1.3",
  "description": "Minimal embeddable wireframe lipsync face renderer — drives expressive character profiles from voice or TTS audio in the browser.",
  "main": "wireface.js",
  "browser": "wireface.js",
  "unpkg": "dist/wireface.min.js",
  "jsdelivr": "dist/wireface.min.js",
  "files": [
    "wireface.js",
    "examples/",
    "docs/",
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "lipsync",
    "viseme",
    "face",
    "avatar",
    "tts",
    "voice",
    "babylon",
    "babylonjs",
    "audio",
    "wireframe",
    "character"
  ],
  "peerDependencies": {
    "babylonjs": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "babylonjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "terser": "^5.31.0"
  },
  "scripts": {
    "build": "mkdir -p dist && cp wireface.js dist/wireface.js && terser wireface.js -c -m --comments=false -o dist/wireface.min.js",
    "prepublishOnly": "npm run build",
    "demo": "npx --yes serve -l 5173 ."
  },
  "author": "Peter Styk",
  "license": "MIT",
  "homepage": "https://github.com/styk-tv/wireface#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/styk-tv/wireface.git"
  },
  "bugs": {
    "url": "https://github.com/styk-tv/wireface/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
